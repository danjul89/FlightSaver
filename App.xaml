<Application x:Class="FlightSaver.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnLastWindowClose"
             Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="BgDeep">#FF050810</Color>
            <Color x:Key="BgEdge">#FF0A1428</Color>
            <Color x:Key="RingStroke">#33FFFFFF</Color>
            <Color x:Key="LabelText">#88FFFFFF</Color>
            <Color x:Key="CenterDot">#FF34D399</Color>
            <Color x:Key="AltLow">#FFFB7185</Color>
            <Color x:Key="AltMid">#FFFCD34D</Color>
            <Color x:Key="AltHigh">#FF67E8F9</Color>
            <SolidColorBrush x:Key="LabelBrush" Color="{StaticResource LabelText}" />
            <SolidColorBrush x:Key="RingBrush" Color="{StaticResource RingStroke}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
